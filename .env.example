# ── Hermes Dashboard — Environment Variables ──────────────────────────────────
# Copy this file to ~/.hermes/.env and customize values.
# The API server reads these at startup from ~/.hermes/.env

# ── Hermes Root ───────────────────────────────────────────────────────────────
# Base directory where Hermes Agent stores its config, state, and data.
# Default: ~/.hermes (matches Hermes CLI default)
# HERMES_ROOT=/home/YOUR_USER/.hermes

# ── API Server ───────────────────────────────────────────────────────────────
# Port for the dashboard API (default: 5174)
# API_PORT=5174

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://127.0.0.1:5173

# ── Authentication ───────────────────────────────────────────────────────────
# Dashboard auth token. Set a value here to protect the dashboard with a login.
# Leave empty for dev mode (open access — no login required, fine for localhost).
# When set: visit /login and enter this token to access the dashboard.
# DASHBOARD_TOKEN=your-secret-token-here

# ── Hermes Binary ─────────────────────────────────────────────────────────────
# Path to the hermes CLI binary. Default: ~/.local/bin/hermes
# Only needed if hermes is installed in a non-standard location.
# HERMES_BIN=/home/YOUR_USER/.local/bin/hermes

# ── Python ────────────────────────────────────────────────────────────────────
# Python interpreter used for database queries and config manipulation.
# Default: /usr/bin/python3
# PYTHON=/usr/bin/python3

# ── Token Key ──────────────────────────────────────────────────────────────
# The localStorage key used to persist the auth token in the browser.
# Only needed if you want a non-default key. Defaults to: hermes_dashboard_token
# VITE_TOKEN_KEY=hermes_dashboard_token
